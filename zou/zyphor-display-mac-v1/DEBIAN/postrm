#!/bin/bash
set -e

if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then

    REAL_USER=$(logname 2>/dev/null || echo "$SUDO_USER")
    REAL_HOME=$(eval echo "~$REAL_USER")

    # Remove compiz config
    rm -f "$REAL_HOME/.config/compiz/compizconfig/Default.ini"

    # Remove autostart entry
    rm -f "$REAL_HOME/.config/autostart/compiz.desktop"

    # Switch back to xfwm4 for current session
    if [ -n "$REAL_USER" ]; then
        XAUTHORITY="$REAL_HOME/.Xauthority"
        sudo -u "$REAL_USER" \
            DISPLAY=":0" \
            XAUTHORITY="$XAUTHORITY" \
            xfwm4 --replace >/dev/null 2>&1 &
    fi

fi

exit 0