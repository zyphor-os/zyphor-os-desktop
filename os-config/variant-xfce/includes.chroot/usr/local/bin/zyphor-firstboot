#!/bin/bash

FLAG="$HOME/.zyphor_firstboot_done"

[ -f "$FLAG" ] && exit 0

echo "INFO: Running Zyphor first boot setup..."

# Load panel profile
if command -v xfce4-panel-profiles >/dev/null 2>&1; then
    xfce4-panel-profiles load "/usr/share/xfce4-panel-profiles/layouts/Redmond 7.tar.bz2"
fi

# Give XFCE a moment to create panel files
sleep 2

# Replace launcher icons
if [ -d "$HOME/.config/xfce4/panel" ]; then
    find "$HOME/.config/xfce4/panel/" -name "*.rc" \
        -exec sed -i 's|^button-icon=.*|button-icon=/usr/share/pixmaps/zyphor-logo.png|' {} +
fi

# Apply theme
xfconf-query -c xsettings -p /Net/ThemeName -s Windows-10
xfconf-query -c xfwm4 -p /general/theme -s Windows-10
xfconf-query -c xsettings -p /Net/IconThemeName -s "Windows-10-Icons"

touch "$FLAG"

echo "INFO: Zyphor first boot setup complete."