#!/bin/bash

zyphor_pkg_remove() {

  APP="$3"

  # ==================================================
  # SAFE DEFAULTS (prevents curl issues)
  # ==================================================
  REGISTRY_URL="${REGISTRY_URL:-https://markjasonespelita.github.io/zyphor_repo/registry/registry.json}"
  CACHE_FILE="${CACHE_FILE:-/tmp/zyphor_registry.json}"

  # ==================================================
  # VALIDATE INPUT
  # ==================================================
  if [ -z "$APP" ]; then
    echo ""
    echo "Zyphor: ✖ Missing app name"
    echo "Usage: zyphor pkg remove <app>"
    echo ""
    return 1
  fi

  # ==================================================
  # ROOT CHECK
  # ==================================================
  if [ "$EUID" -ne 0 ]; then
    echo ""
    echo "Zyphor: ⚠ Requires root privileges"
    echo "Try: sudo zyphor pkg remove $APP"
    echo ""
    return 1
  fi

  # ==================================================
  # LOAD REGISTRY (WITH FALLBACK)
  # ==================================================
  echo ""
  echo "Zyphor: Loading registry..."

  if ! curl -fsSL "$REGISTRY_URL" -o "$CACHE_FILE"; then
    echo "Zyphor: ⚠ Failed writing to $CACHE_FILE"

    CACHE_FILE="/var/tmp/zyphor_registry.json"
    echo "Zyphor: Retrying → $CACHE_FILE"

    if ! curl -fsSL "$REGISTRY_URL" -o "$CACHE_FILE"; then
      echo "Zyphor: ⚠ Using cached registry..."

      if [ ! -f "$CACHE_FILE" ]; then
        echo "Zyphor: ✖ No registry available"
        return 1
      fi
    fi  fi

  # ==================================================
  # RESOLVE APP
  # ==================================================
  TYPE=$(jq -r ".apps.\"$APP\".type // empty" "$CACHE_FILE")
  PACKAGE=$(jq -r ".apps.\"$APP\".package // empty" "$CACHE_FILE")
  MODULE=$(jq -r ".apps.\"$APP\".module // empty" "$CACHE_FILE")

  if [ -z "$TYPE" ]; then
    echo ""
    echo "Zyphor: ✖ App not found → $APP"
    return 1
  fi

  # ==================================================
  # SAFETY CONFIRMATION
  # ==================================================
  echo ""
  echo "Zyphor: You are about to remove:"
  echo "  App   : $APP"
  echo "  Type  : $TYPE"

  if [ -n "$PACKAGE" ]; then
    echo "  Target: $PACKAGE"
  fi

  echo ""

  read -p "Continue? [y/N]: " CONFIRM
  case "$CONFIRM" in
    y|Y) ;;
    *)
      echo "Zyphor: Cancelled."
      echo ""
      return 0
      ;;
  esac

  # ==================================================
  # REMOVE ENGINE
  # ==================================================
  echo ""
  echo "Zyphor: Removing '$APP'..."
  echo ""

  case "$TYPE" in

    # --------------------------
    # APT + DEB (UNIFIED + FALLBACK DETECTION)
    # --------------------------
    apt|deb)

      # fallback if package missing
      if [ -z "$PACKAGE" ]; then
        echo "Zyphor: ⚠ No package defined, attempting detection..."

        PACKAGE=$(dpkg -l | awk '{print $2}' | grep -i "^$APP" | head -n 1)

        # second fallback (looser match)
        if [ -z "$PACKAGE" ]; then
          PACKAGE=$(dpkg -l | awk '{print $2}' | grep -i "$APP" | head -n 1)
        fi

        if [ -z "$PACKAGE" ]; then
          echo "Zyphor: ✖ Could not determine package name"
          return 1
        fi

        echo "Zyphor: Using detected package → $PACKAGE"
      fi

      echo "Zyphor: Removing package → $PACKAGE"

      if dpkg -s "$PACKAGE" >/dev/null 2>&1; then
        apt remove -y "$PACKAGE"
      else
        echo "Zyphor: ⚠ Package not installed → $PACKAGE"
      fi
      ;;

    # --------------------------
    # SNAP
    # --------------------------
    snap)

      if [ -z "$PACKAGE" ]; then
        echo "Zyphor: ✖ Missing snap package"
        return 1
      fi

      echo "Zyphor: Removing Snap → $PACKAGE"

      if snap list 2>/dev/null | awk '{print $1}' | grep -qx "$PACKAGE"; then
        snap remove "$PACKAGE"
      else
        echo "Zyphor: ⚠ Snap not installed → $PACKAGE"
      fi
      ;;

    # --------------------------
    # INTERNAL MODULE
    # --------------------------
    internal)

      if [ -z "$MODULE" ]; then
        echo "Zyphor: ✖ Missing module"
        return 1
      fi

      echo "Zyphor: Removing internal module → $MODULE"
      bash "/usr/lib/zyphor/modules/$MODULE/remove.sh"
      ;;

    # --------------------------
    # UNKNOWN TYPE
    # --------------------------
    *)
      echo "Zyphor: ✖ Unknown type → $TYPE"
      return 1
      ;;
  esac

  # ==================================================
  # OPTIONAL CLEANUP
  # ==================================================
  echo ""
  read -p "Zyphor: Run autoremove (cleanup dependencies)? [y/N]: " AUTO

  if [[ "$AUTO" =~ ^[yY]$ ]]; then
    apt autoremove -y
    echo "Zyphor: ✔ Cleanup complete"
  fi

  echo ""
  echo "Zyphor: ✔ Successfully processed removal of '$APP'"
  echo ""
}