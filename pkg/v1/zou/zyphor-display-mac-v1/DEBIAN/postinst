#!/bin/bash
set -e

REAL_USER=$(logname 2>/dev/null || echo "$SUDO_USER")
REAL_HOME=$(eval echo "~$REAL_USER")
COMPIZ_CONFIG="$REAL_HOME/.config/compiz/compizconfig"
AUTOSTART_DIR="$REAL_HOME/.config/autostart"

# Create config directories
mkdir -p "$COMPIZ_CONFIG"
mkdir -p "$AUTOSTART_DIR"

# Write compiz config
cat > "$COMPIZ_CONFIG/Default.ini" <<'EOF'
[core]
active_plugins = core;composite;opengl;decor;move;resize;place;regex;animation;wobblywindows;fade;

[animation]
open_effects = animation:Zoom;
close_effects = animation:Glide 2;
minimize_effects = animation:None;
unminimize_effects = animation:None;
minimize_matches = (type=Normal | type=Dialog | type=ModalDialog | type=Unknown);
unminimize_matches = (type=Normal | type=Dialog | type=ModalDialog | type=Unknown);

[wobblywindows]
friction = 3.0
spring_k = 8.0

[regex]
enabled = true
EOF

# Create autostart entry so compiz survives reboot
cat > "$AUTOSTART_DIR/compiz.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=Compiz
Exec=compiz --replace
X-GNOME-Autostart-enabled=true
NoDisplay=false
EOF

# Fix ownership
chown -R "$REAL_USER:$REAL_USER" "$REAL_HOME/.config/compiz"
chown -R "$REAL_USER:$REAL_USER" "$AUTOSTART_DIR"

# Start compiz immediately for current session
if [ -n "$REAL_USER" ]; then
    XAUTHORITY="$REAL_HOME/.Xauthority"
    sudo -u "$REAL_USER" \
        DISPLAY=":0" \
        XAUTHORITY="$XAUTHORITY" \
        compiz --replace >/dev/null 2>&1 &
fi

exit 0