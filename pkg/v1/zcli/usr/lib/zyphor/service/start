#!/bin/bash

# zyphor service start <service>

zyphor_service_start() {

  SERVICE="$3"

  if [ -z "$SERVICE" ]; then
    echo ""
    echo "Zyphor: ✖ Missing service name"
    echo "Usage: zyphor service start <service>"
    echo ""
    return 1
  fi

  if [ "$EUID" -ne 0 ]; then
    echo ""
    echo "Zyphor: ⚠ Requires root privileges"
    echo "Try: sudo zyphor service start $SERVICE"
    echo ""
    return 1
  fi

  echo ""
  echo "Zyphor: Starting '$SERVICE'..."

  if systemctl start "$SERVICE"; then
    echo "Zyphor: ✔ '$SERVICE' started successfully"
  else
    echo "Zyphor: ✖ Failed to start '$SERVICE'"
  fi

  echo ""
}