#!/bin/bash
#
# zyphor_setup_theme — desktop theme switcher for Zyphor OS
#
# Usage: zyphor setup theme <target>
# Targets: light, dark
#

# ======================================================================
# HELPERS
# ======================================================================

# xfconf-query talks to the XFCE session bus, so it must run as the
# real desktop user (not root) and with that user's DBus/X session env.
# This mirrors the real-user resolution used in zyphor_setup_dev to
# avoid writing theme settings into the wrong user's xfconf channel.
_zyphor_resolve_real_user() {
  local candidate=""

  if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
    candidate="$SUDO_USER"
  elif command -v logname >/dev/null 2>&1 && logname >/dev/null 2>&1; then
    candidate="$(logname 2>/dev/null)"
  fi

  if [ -z "$candidate" ] || [ "$candidate" = "root" ]; then
    local tty_owner
    tty_owner="$(stat -c '%U' "$(tty 2>/dev/null)" 2>/dev/null)"
    if [ -n "$tty_owner" ] && [ "$tty_owner" != "root" ]; then
      candidate="$tty_owner"
    fi
  fi

  if [ -z "$candidate" ]; then
    candidate="$USER"
  fi

  echo "$candidate"
}

_zyphor_user_uid() {
  id -u "$1" 2>/dev/null
}

# Run an xfconf-query command as the target user with the correct
# DBus session bus address, so the change actually reaches their
# running XFCE session instead of silently doing nothing (or worse,
# creating a stray session bus as root).
_zyphor_run_as_user() {
  local user="$1"
  shift
  local uid
  uid="$(_zyphor_user_uid "$user")"

  if [ -z "$uid" ]; then
    echo "Zyphor: ✖ Could not resolve UID for user '$user'"
    return 1
  fi

  sudo -u "$user" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
    DISPLAY="${DISPLAY:-:0}" \
    "$@"
}

_zyphor_apply_theme() {
  local user="$1" theme_name="$2"

  echo "Zyphor: Applying '$theme_name' theme for $user..."

  _zyphor_run_as_user "$user" xfconf-query -c xsettings -p /Net/ThemeName -s "$theme_name" || {
    echo "Zyphor: ✖ Failed setting xsettings theme"
    return 1
  }

  _zyphor_run_as_user "$user" xfconf-query -c xfwm4 -p /general/theme -s "$theme_name" || {
    echo "Zyphor: ✖ Failed setting xfwm4 theme"
    return 1
  }
}

# ======================================================================
# LIGHT / DARK TARGETS
# ======================================================================

_zyphor_setup_theme_light() {
  local ORIGINAL_USER
  ORIGINAL_USER="$(_zyphor_resolve_real_user)"

  echo ""
  echo "Zyphor: 🚀 Setting theme → Light (Windows-10)"
  echo "Zyphor: Detected target user → $ORIGINAL_USER"
  echo ""

  _zyphor_apply_theme "$ORIGINAL_USER" "Windows-10" || return 1

  echo ""
  echo "Zyphor: ✔ Light theme applied"
  echo ""
}

_zyphor_setup_theme_dark() {
  local ORIGINAL_USER
  ORIGINAL_USER="$(_zyphor_resolve_real_user)"

  echo ""
  echo "Zyphor: 🚀 Setting theme → Dark (Kali-Dark)"
  echo "Zyphor: Detected target user → $ORIGINAL_USER"
  echo ""

  _zyphor_apply_theme "$ORIGINAL_USER" "Kali-Dark" || return 1

  echo ""
  echo "Zyphor: ✔ Dark theme applied"
  echo ""
}

# ======================================================================
# MAIN ENTRY POINT
# ======================================================================

zyphor_setup_theme() {
  local TARGET="$3"
  local status

  if [ -z "$TARGET" ]; then
    echo ""
    echo "Zyphor: ✖ Missing theme target"
    echo "Usage: zyphor setup theme <target>"
    echo "Example: zyphor setup theme dark"
    echo ""
    return 1
  fi

  if ! command -v xfconf-query >/dev/null 2>&1; then
    echo ""
    echo "Zyphor: ✖ xfconf-query not found — is XFCE installed?"
    echo ""
    return 1
  fi

  echo ""
  echo "Zyphor: 🚀 Setting up theme → $TARGET"
  echo ""

  case "$TARGET" in
    light) _zyphor_setup_theme_light ;;
    dark)  _zyphor_setup_theme_dark ;;
    *)
      echo ""
      echo "Zyphor: ✖ Unknown theme target → $TARGET"
      echo "Available targets: light, dark"
      echo ""
      return 1
      ;;
  esac
  status=$?

  if [ "$status" -eq 0 ]; then
    echo ""
    echo "Zyphor: ✔ Theme setup '$TARGET' completed"
    echo ""
  else
    echo ""
    echo "Zyphor: ✖ Theme setup failed → $TARGET"
    echo ""
    return 1
  fi
}