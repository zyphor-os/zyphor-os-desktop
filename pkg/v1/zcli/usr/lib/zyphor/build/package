#!/bin/bash

# zyphor build package <package-folder-name>

zyphor_build_package() {
  PKG_DIR="$3"

  # Default to current directory if not provided
  if [ -z "$PKG_DIR" ]; then
    PKG_DIR="."
  fi

  echo "[zyphor] Building .deb package from: $PKG_DIR"

  # Validate directory
  if [ ! -d "$PKG_DIR" ]; then
    echo "[error] Directory '$PKG_DIR' not found"
    exit 1
  fi

  # Validate Debian structure
  if [ ! -f "$PKG_DIR/DEBIAN/control" ]; then
    echo "[error] '$PKG_DIR' is not a valid Debian package (missing DEBIAN/control)"
    exit 1
  fi

  dpkg-deb --build "$PKG_DIR"

  if [ $? -eq 0 ]; then
    echo "[zyphor] Package build complete: ${PKG_DIR%/}.deb"
  else
    echo "[error] Package build failed"
    exit 1
  fi
}