#!/bin/bash

zyphor_smb_mount() {

  source /usr/lib/zyphor/smb/ensure
  zyphor_smb_ensure || return 1

  if [ "$EUID" -ne 0 ]; then
    echo ""
    echo "Zyphor: ⚠ Requires root"
    echo "Try: sudo zyphor smb mount"
    echo ""
    return 1
  fi

  read -p "IP Address: " IP
  read -p "Share Name: " SHARE
  read -p "Username: " USER
  read -s -p "Password: " PASS
  echo ""

  if [ -z "$IP" ] || [ -z "$SHARE" ] || [ -z "$USER" ]; then
    echo "Zyphor: ✖ Missing required input"
    return 1
  fi

  MOUNT_POINT="/mnt/zyphor_${SHARE}"
  mkdir -p "$MOUNT_POINT"

  echo ""
  echo "Zyphor: Mounting //$IP/$SHARE → $MOUNT_POINT"

  mount -t cifs "//$IP/$SHARE" "$MOUNT_POINT" \
    -o username="$USER",password="$PASS",rw

  if [ $? -eq 0 ]; then
    echo "Zyphor: ✔ Mounted successfully"
  else
    echo "Zyphor: ✖ Mount failed"
    return 1
  fi

  echo ""
}