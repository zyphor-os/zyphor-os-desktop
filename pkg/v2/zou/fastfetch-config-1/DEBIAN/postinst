#!/bin/bash
set -e

echo "Applying Zyphor Fastfetch configuration..."

# Loop through all real users (UID >= 1000)
for user in $(awk -F: '$3 >= 1000 && $3 < 65534 {print $1}' /etc/passwd); do
    home_dir=$(eval echo "~$user")

    # Skip if no home dir
    [ -d "$home_dir" ] || continue

    config_dir="$home_dir/.config/fastfetch"
    config_file="$config_dir/config.jsonc"

    mkdir -p "$config_dir"

    # Option A: overwrite user config
    cp /etc/fastfetch/config.jsonc "$config_file"

    # Fix ownership
    chown -R "$user:$user" "$home_dir/.config"

done

echo "Fastfetch config applied to all users."