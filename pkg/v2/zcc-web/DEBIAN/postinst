#!/bin/sh
set -e

APP_DIR="/usr/share/zyphor-command-center-web"

if [ -d "$APP_DIR" ]; then
    cd "$APP_DIR"

    # profile.json now lives in the logged-in user's home directory
    # (~/.config/zyphor-command-center-web/profile.json), created lazily by
    # the app on first run. Nothing to seed here — postinstall runs as root
    # and has no reliable way to know which desktop user's $HOME to write to.

    # Ensure the avatar upload directory exists — do not clear it if it
    # already has files, those belong to the user
    mkdir -p assets/uploads/avatars

    # Permissions: web server needs to read/write uploads
    chmod -R 775 assets/uploads || true
fi

exit 0
