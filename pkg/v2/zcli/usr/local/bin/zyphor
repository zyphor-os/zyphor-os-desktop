#!/bin/bash

# ================= CORE =================
source /usr/lib/zyphor/core/help
source /usr/lib/zyphor/core/error

CATEGORY="$1"
ACTION="$2"

case "$CATEGORY" in

  # ================= BUILD =================
  build)
    source /usr/lib/zyphor/build/package
    source /usr/lib/zyphor/build/repo

    case "$ACTION" in
      package) zyphor_build_package "$@" ;;
      repo)    zyphor_build_repo "$@" ;;
      *) error "build $ACTION" ;;
    esac
    ;;

  # ================= PKG =================
  pkg)
    source /usr/lib/zyphor/pkg/install
    source /usr/lib/zyphor/pkg/remove
    source /usr/lib/zyphor/pkg/list
    source /usr/lib/zyphor/pkg/search
    source /usr/lib/zyphor/pkg/cache

    case "$ACTION" in
      install)
        zyphor_pkg_cache
        zyphor_pkg_install "$@"
      ;;

      remove)
        zyphor_pkg_cache
        zyphor_pkg_remove "$@"
      ;;

      list)
        zyphor_pkg_cache
        zyphor_pkg_list "$@"
      ;;

      search)
        zyphor_pkg_cache
        zyphor_pkg_search "$@"
      ;;

      *)
        error "pkg $ACTION"
      ;;
    esac
  ;;

  # ================= SERVICE =================
  service)
    source /usr/lib/zyphor/service/list
    source /usr/lib/zyphor/service/start
    source /usr/lib/zyphor/service/stop
    source /usr/lib/zyphor/service/restart
    source /usr/lib/zyphor/service/status

    case "$ACTION" in
      list)    zyphor_service_list "$@" ;;
      start)   zyphor_service_start "$@" ;;
      stop)    zyphor_service_stop "$@" ;;
      restart) zyphor_service_restart "$@" ;;
      status)  zyphor_service_status "$@" ;;
      *) error "service $ACTION" ;;
    esac
    ;;

  # ================= DOCTOR =================
  doctor)
    source /usr/lib/zyphor/doctor/fix
    source /usr/lib/zyphor/doctor/report
    source /usr/lib/zyphor/doctor/scan

    case "$ACTION" in
      fix)    zyphor_doctor_fix "$@" ;;
      report) zyphor_doctor_report "$@" ;;
      scan)   zyphor_doctor_scan "$@" ;;
      *) error "doctor $ACTION" ;;
    esac
    ;;

  # ================= SYSTEM =================
  system)
    source /usr/lib/zyphor/system/upgrade
    source /usr/lib/zyphor/system/clean
    source /usr/lib/zyphor/system/info

    case "$ACTION" in
      upgrade) zyphor_system_upgrade ;;
      clean)   zyphor_system_clean ;;
      info)    zyphor_system_info ;;
      *) error "system $ACTION" ;;
    esac
    ;;

  # ================= SMB =================
  smb)
    source /usr/lib/zyphor/smb/list
    source /usr/lib/zyphor/smb/mount
    source /usr/lib/zyphor/smb/disk-list
    source /usr/lib/zyphor/smb/disk-mount

    case "$ACTION" in
      list)       zyphor_smb_list "$@" ;;
      mount)      zyphor_smb_mount "$@" ;;
      disk-list)  zyphor_smb_disk_list "$@" ;;
      disk-mount) zyphor_smb_disk_mount "$@" ;;
      *) error "smb $ACTION" ;;
    esac
  ;;

  # ================= FTP =================
  ftp)
    source /usr/lib/zyphor/ftp/list
    source /usr/lib/zyphor/ftp/upload
    source /usr/lib/zyphor/ftp/download

    case "$ACTION" in
      list)     zyphor_ftp_list "$@" ;;
      upload)   zyphor_ftp_upload "$@" ;;
      download) zyphor_ftp_download "$@" ;;
      *) error "ftp $ACTION" ;;
    esac
  ;;

  # ================= SSH =================
  ssh)
    source /usr/lib/zyphor/ssh/connect
    source /usr/lib/zyphor/ssh/cmd

    case "$ACTION" in
      connect) zyphor_ssh_connect "$@" ;;
      cmd)     zyphor_ssh_cmd "$@" ;;
      *) error "ssh $ACTION" ;;
    esac
  ;;

  # ================= SETUP =================
  setup)
    source /usr/lib/zyphor/setup/dev
    source /usr/lib/zyphor/setup/theme
    source /usr/lib/zyphor/setup/wine

    case "$ACTION" in
      dev)
        zyphor_setup_dev "$@"
      ;;
      theme)
        zyphor_setup_theme "$@"
      ;;
      wine)
        zyphor_setup_wine
      ;;
      *)
        error "setup $ACTION"
      ;;
    esac
  ;;

  # ================= META =================
  help|"") help ;;
  *) error "$CATEGORY" ;;

esac
