# =========================================================
# 5. Prepare chroot environment
# =========================================================

sudo mount --bind /dev extract/dev
sudo mount --bind /proc extract/proc
sudo mount --bind /sys extract/sys
sudo mount --bind /run extract/run
sudo mount -t devpts devpts extract/dev/pts

# DNS fix
sudo cp /etc/resolv.conf extract/etc/resolv.conf

# =========================================================
# 6. Enter chroot
# =========================================================

sudo chroot extract /bin/zsh

# =========================================================
# 7. INSIDE CHROOT
# =========================================================

# Fix repositories if needed
nano /etc/apt/sources.list

# Example Kali repo:
# deb http://http.kali.org/kali kali-rolling main contrib non-free non-free-firmware

# Clean broken apt lists
apt clean
rm -rf /var/lib/apt/lists/*

# Update package database
apt update

# Install packages
apt install htop ufw

# Edit system files
nano /etc/os-release

# Optional cleanup
apt clean
rm -rf /tmp/*
history -c
rm -f ~/.bash_history

# =========================================================
# 8. EXIT CHROOT
# =========================================================

exit

# =========================================================
# 9. Unmount chroot filesystems
# =========================================================

sudo umount extract/dev/pts
sudo umount extract/dev
sudo umount extract/proc
sudo umount extract/sys
sudo umount extract/run

# =========================================================
# 10. Remove old squashfs
# =========================================================

sudo rm -rf iso/live/filesystem.squashfs

# =========================================================
# 11. Rebuild squashfs
# =========================================================

sudo mksquashfs extract iso/live/filesystem.squashfs -comp xz

# =========================================================
# 12. Rebuild ISO
# =========================================================

cd iso

sudo xorriso -as mkisofs \
  -iso-level 3 \
  -full-iso9660-filenames \
  -volid "Kali Live" \
  -o ../new-iso/zyphor-custom.iso \
  -eltorito-boot isolinux/isolinux.bin \
    -eltorito-catalog isolinux/boot.cat \
    -no-emul-boot \
    -boot-load-size 4 \
    -boot-info-table \
  -isohybrid-mbr /usr/lib/ISOLINUX/isohdpfx.bin \
  -eltorito-alt-boot \
    -e boot/grub/efi.img \
    -no-emul-boot \
  -isohybrid-gpt-basdat \
  .

